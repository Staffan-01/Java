import java.util.*;
public class Main
{
	public static void main(String[] args) {
		Scanner sc=new Scanner(System.in);
		int n=sc.nextInt(),og=2*n,count=0;
		for(int i=1;i<=n;i++){
		    if(n%i==0){
		        count+=i;
		    }
		}
		boolean f=count<og;
		System.out.println(count+" < "+og+" = "+f);
		System.out.println(count<og?"Deficient Number":"Not a Deficient Number");
	}
}
