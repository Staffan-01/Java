import java.util.*;
public class Main
{
	public static void main(String[] args) {
		Scanner sc=new Scanner(System.in);
		int n1=sc.nextInt(),n2=sc.nextInt(),rev=0;
		while(n1!=0){
		    rev=rev*10+n1%10;
		    n1/=10;
		}
		System.out.print(rev==n2?"Rotation Numbers":"Not a Rotation Numbers");
	}
}
