import java.util.*;
public class Main
{
	public static void main(String[] args) {
		Scanner sc=new Scanner(System.in);
		int n=sc.nextInt();
		ArrayList<Integer> list=new ArrayList<>();
		for(int i=2;i<=Math.sqrt(n);i++){
		    if(n%i==0){
		        list.add(i);
		        while(n%i==0){
		            n/=10;
		        }
		    }
		}
		if(n>1)
		    list.add(n);
		System.out.print(list);
	}
}
