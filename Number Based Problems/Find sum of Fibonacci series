import java.util.*;
public class Main
{
    int fib(int n){
        if(n<=1)
            return n;
        else
            return fib(n-1)+fib(n-2);
    }
	public static void main(String[] args) {
		Scanner sc=new Scanner(System.in);
		int n=sc.nextInt(),ans=0;
		Main ob=new Main();
		for(int i=0;i<=n;i++){
		    ans+=ob.fib(i);
		}
		System.out.print(ans);
	}
}
