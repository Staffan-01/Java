import java.util.*;
public class Main
{
	public static void main(String[] args) {
		Scanner sc=new Scanner(System.in);
		int n=sc.nextInt(),f=0;
		while(n>10){
		    if((n%100/10)>=n%10){
		        f=1;
		    }else{
		        f=0;break;
		    }
		  //  System.out.println((n%100/10)+" > "+n%10+" = "+f);
		    n/=10;
		}
		System.out.println(f==1?"Decreasing digits":"Not contains Decreasing digits");
	}
}
