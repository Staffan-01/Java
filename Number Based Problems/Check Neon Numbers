import java.util.*;
public class Main
{
	public static void main(String[] args) {
		Scanner sc=new Scanner(System.in);
		int n=sc.nextInt(),og=n,ans=0,sqr=0;
		sqr=n*n;
		while(sqr!=0){
		    ans+=sqr%10;
		    sqr/=10;
		}
		System.out.println(ans==og?"Yes":"No");
	}
}


