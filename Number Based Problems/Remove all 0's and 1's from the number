import java.util.*;
public class Main
{
	public static void main(String[] args) {
		Scanner sc=new Scanner(System.in);
		int n=sc.nextInt(),f=0;
		while(n!=0){
		    if((n%10)!=0 && (n%10)!=1){
		        f=f*10+n%10;
		    }
		    n/=10;
		}
		while(f!=0){
		    n=n*10+f%10;
		    f/=10;
		}
		System.out.print(n);
	}
}
