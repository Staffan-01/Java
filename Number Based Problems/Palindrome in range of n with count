import java.util.*;
public class Main
{
	public static void main(String[] args) {
		Scanner sc=new Scanner(System.in);
		int n=sc.nextInt(),rev=0,temp=0,count=0;
		for(int i=1;i<=n;i++){
		    temp=i;rev=0;
    		while(temp!=0){
    		    rev=rev*10+temp%10;
    		    temp/=10;
    		}
    		if(i==rev){
    		    System.out.print(i+" ");
    		    count++;
    		}
		}
		System.out.println("\nCount of Palindrome Numbers:"+count);
	}
}
