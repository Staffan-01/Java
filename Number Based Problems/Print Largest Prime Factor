import java.util.*;
public class Main
{
	public static void main(String[] args) {
		Scanner sc=new Scanner(System.in);
		int n=sc.nextInt(),ans=0;
		for(int i=1;i<n;i++){
		    if(n%i==0){
		        boolean f=false;
		        for(int j=2;j<=i/2;j++){
		            if(i%j==0){
		                f=true;
		                break;
		            }
		        }
		        if(f==false)  
		            ans=i;
		    }
		}
		System.out.print(ans);
	}
}
