import java.util.*;
public class Main{
	public static void main(String[] args) {
		Scanner sc=new Scanner(System.in);
		int num=sc.nextInt();
		for(int n=1;n<=num;n++){
		    int f=1;
    		for(int i=2;i<=n/2;i++){
    		    if(n%i==0){
    		        f=0;
    		        break;
    		    }
    		}
    		if(f==1)
    		    System.out.print(n+" ");
		}
	}
}
