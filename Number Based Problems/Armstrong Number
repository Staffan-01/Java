import java.util.*;
public class Main
{
	public static void main(String[] args) {
		Scanner sc=new Scanner(System.in);
		int n=sc.nextInt(),og=n,temp=n,count=0,ans=0;
		while(temp!=0){
		    count++;temp/=10;
		}
		while(n!=0){
		    ans+=(int)Math.pow(n%10,count);
		    n/=10;
		}
		System.out.print(ans==og?"Armstrong Number":"Not an Armstrong Number");
	}
}
