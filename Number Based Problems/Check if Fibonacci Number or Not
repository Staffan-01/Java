import java.util.*;
public class Main
{
    int fib(int n){
        if(n<=1)
            return n;
        else
            return fib(n-1)+fib(n-2);
    }
	public static void main(String[] args) {
		Scanner sc=new Scanner(System.in);
		int n=sc.nextInt();
		boolean f=false;
		Main ob=new Main();
		for(int i=0;i<=n;i++){
		    if(n==ob.fib(i)){
		        f=true;break;
		    }
		}
		System.out.print(f?"Fibonacci Number":"Not a Fibonacci Number");
	}
}
