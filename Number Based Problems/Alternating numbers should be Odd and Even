import java.util.*;
public class Main
{
	public static void main(String[] args) {
		Scanner sc=new Scanner(System.in);
		int n=sc.nextInt(),f=0;
		while(n!=0){
		    if(((n%100/10)%2==0)&&((n%10)%2!=0) || ((n%100/10)%2!=0)&&((n%10)%2==0)){
		        f=1;
		    }else{
		        f=0;
		        break;
		    }
		    n/=10;
		}
		System.out.print(f==1?"Yes":"No");
	}
}
