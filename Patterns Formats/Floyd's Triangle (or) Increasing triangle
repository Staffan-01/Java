import java.util.*;
public class Main
{
	public static void main(String[] args) {
		Scanner sc=new Scanner(System.in);
		int n=sc.nextInt(),a=1;
		for(int i=0;i<=n;i++){
		    for(int j=0;j<i;j++){
		        if(a<10)
		            System.out.print((a++)+"  ");
		        else
    		        System.out.print((a++)+" ");
		    }
		    System.out.println();
		}
	}
}
