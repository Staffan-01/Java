import java.util.*;
public class Main
{
	public static void main(String[] args) {
		Scanner sc=new Scanner(System.in);
		int n=sc.nextInt();
		int arr[]=new int[n];
		for(int i=0;i<n;arr[i++]=sc.nextInt());
		int number=sc.nextInt();
		boolean f=true;
		for(int i=0;i<n-1;i++){
		    if(arr[i]+arr[i+1]==number){
		        System.out.println(arr[i]+" "+arr[i+1]);
		        f=false;
		    }
		}
		if(f) System.out.print("No possible Combinations available");
	}
}
