import java.util.*;
public class Main{
	public static void main(String[] args) {
		Scanner sc=new Scanner(System.in);
		int n=sc.nextInt(),temp=0;
		int arr[]=new int[n];
		for(int i=0;i<n;arr[i++]=sc.nextInt());
		int ans[]=new int[n];
		for(int i=(n-1)/2;i>=0;i--){
		    ans[temp]=arr[i];
		    System.out.print(ans[temp++]+" ");
		}
		System.out.println();
		for(int i=(n+1)/2;i<n;i++){
		    ans[temp++]=arr[i];
		}
		for(int i=0;i<n;System.out.print(ans[i++]+" "));
	}
}
